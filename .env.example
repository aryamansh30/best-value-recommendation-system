FAKESTORE_URL=https://fakestoreapi.com/products
REQUEST_TIMEOUT_SEC=15
SSL_CA_BUNDLE=

# Provider switch: ollama | openai
# Used only for GenAI synonym fallback on deterministic no-match queries.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional RapidAPI source
USE_RAPIDAPI=false
RAPIDAPI_URL=https://real-time-amazon-data.p.rapidapi.com/search
RAPIDAPI_HOST=real-time-amazon-data.p.rapidapi.com
RAPIDAPI_KEY=
RAPIDAPI_REGION=US
